# ---- Copy to .env and fill in when you have the credentials ----
# The app runs WITHOUT these (it falls back to mock data); fill them to go live.

# OpenRouter (flash model for competitor discovery + ad understanding)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Database (ad store) — URL + token you will provide
DATABASE_URL=
DATABASE_TOKEN=

# RapidAPI — one key drives Instagram/Google/YouTube/Facebook; Twitter/X can use its own
RAPIDAPI_KEY=
RAPIDAPI_FACEBOOK_HOST=facebook-pages-scraper2.p.rapidapi.com
RAPIDAPI_INSTAGRAM_HOST=instagram120.p.rapidapi.com
RAPIDAPI_GOOGLE_HOST=google-search74.p.rapidapi.com
RAPIDAPI_YOUTUBE_HOST=youtube138.p.rapidapi.com
RAPIDAPI_TWITTER_HOST=twitter241.p.rapidapi.com
RAPIDAPI_TWITTER_KEY=          # optional; falls back to RAPIDAPI_KEY if blank

# CORS: the frontend origin during development
FRONTEND_ORIGIN=http://localhost:5173
